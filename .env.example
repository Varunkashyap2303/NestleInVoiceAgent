# ─────────────────────────────────────────────────────────────
# Voice Agent — Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Twilio (required)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+61...      # Your Twilio number in E.164 format

# Deepgram (required)
DEEPGRAM_API_KEY=...

# TTS provider: "twilio_polly" (default, free) or "elevenlabs" (better quality)
TTS_PROVIDER=twilio_polly

# ElevenLabs (optional — only needed if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel voice

# AskIzzy (optional — Australia's largest service directory)
# Apply for API access at: https://github.com/ask-izzy/ask-izzy
ASKIZZY_API_KEY=

# Optional: URL to a self-hosted Polly synthesis endpoint
# See README for how to set this up
POLLY_SYNTHESIS_URL=
